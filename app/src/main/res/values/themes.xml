<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.HarryPotter" parent="Theme.Material3.DayNight.NoActionBar">

        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="colorPrimary">@color/gold</item>
        <item name="colorSecondary">@color/purple_magic</item>

        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <style name="Theme.HarryPotter" parent="Base.Theme.HarryPotter" />

    <style name="Theme.App.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_profile</item>
        <item name="postSplashScreenTheme">@style/Base.Theme.HarryPotter</item>
    </style>

    <style name="AppActiveIndicatorStyle" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">#454459</item>
    </style>
</resources>